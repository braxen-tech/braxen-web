# Resend — envio de e-mails do formulário de contato
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Domínio verificado no Resend
RESEND_FROM_EMAIL=contact@braxentech.com
RESEND_FROM_NAME=Braxen Tech

# Destino dos leads enviados pelo site
CONTACT_EMAIL_TO=contact@braxentech.com

# Google Analytics 4 (opcional — habilita gtag.js no site)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads conversão (opcional — formato AW-XXXXXXXXX/YYYYYYYYYY)
NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXX/YYYYYYYYYY
